rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Menu items can be read by anyone (guests), managed by admin
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if true; // In production, restrict to authenticated admin
    }
    
    // Orders can be created by guests, and read/updated by anyone/admin
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    // Alerts can be created by guests, and read/updated by staff
    match /alerts/{alertId} {
      allow read, write: if true;
    }
    
    // Financial ledger can be read and written by admin/staff
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
  }
}
